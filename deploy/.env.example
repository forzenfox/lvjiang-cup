# ==========================================
# 驴酱杯赛事网站 - 环境变量配置
# ==========================================
# 将此文件复制为 .env 并根据实际情况修改配置
# cp .env.example .env
#
# 注意：
# - 此文件位于 /deploy 目录
# - 此配置用于方案 C（Nginx Proxy Manager 统一网关）
# - 无需配置 SSL 证书，由 NPM 统一管理

# GitHub 配置（用于拉取镜像）
GITHUB_OWNER=your-github-username
GITHUB_REPO=lvjiang-cup
TAG=latest

# ==========================================
# 安全密钥（必须修改！）
# 生成随机字符串：openssl rand -base64 32
# ==========================================
JWT_SECRET=your-random-secret-key-change-this

# ==========================================
# 管理员账号（必须修改密码！）
# ==========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# ==========================================
# CORS 配置（你的域名）
# ==========================================
CORS_ORIGIN=https://your-domain.com

# ==========================================
# 前端配置（config.js）
# ==========================================
# 前端运行时配置通过 config.js 文件挂载，无需重新构建镜像即可修改
# 文件位置：deploy/config.js
#
# 常用配置项：
# - API_BASE_URL: API 地址（默认使用相对路径 '/api'，通过 NPM 代理）
#
# 修改方法：
# 1. 编辑 deploy/config.js 文件
# 2. 执行 docker-compose restart frontend 生效
# 3. 用户刷新浏览器即可看到新配置

# ==========================================
# 部署说明（方案 C）
# ==========================================
# 1. 部署 Nginx Proxy Manager:
#    cd /opt/nginx-proxy-manager
#    docker-compose up -d
#
# 2. 访问 NPM 管理界面：
#    http://服务器 IP:8181
#    默认账号：admin@example.com
#    默认密码：changeme
#
# 3. 配置代理主机：
#    - Domain: your-domain.com
#    - Forward IP: 127.0.0.1
#    - Forward Port: 3001 (前端)
#    - 启用 SSL (Request a new SSL certificate)
#
# 4. 添加 API 路由（高级配置）：
#    - Location: /api
#    - Forward Port: 3000 (后端)
#
# 5. 部署驴酱杯应用：
#    cd /opt/lvjiang-cup/deploy
#    ./deploy.sh
#
# 6. （可选）修改前端配置：
#    vim /opt/lvjiang-cup/deploy/config.js
#    docker-compose restart frontend
