# E2E 测试环境变量配置
# 复制此文件为 .env 并修改相应的值

# 后端服务地址
BACKEND_URL=http://localhost:3000

# 管理员账号（用于调用清空数据 API）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 前端服务地址（通常不需要修改）
FRONTEND_URL=http://localhost:5173

# 测试配置
# 是否启用数据清理（默认：true）
ENABLE_DATA_CLEANUP=true

# 清理超时时间（毫秒，默认：10000）
CLEANUP_TIMEOUT=10000
